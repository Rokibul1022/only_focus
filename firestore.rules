rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can read/write their own profile
    match /users/{userId} {
      // Allow read for authenticated users (including anonymous)
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow create for new users (including anonymous)
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow update for own profile
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // User's subcollections
      match /readHistory/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /rewards/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /badges/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /highlights/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /notes/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Leaderboard - everyone can read, only authenticated users can write their own
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }
    
    // Global stats - read only for authenticated users
    match /stats/{document=**} {
      allow read: if request.auth != null;
    }
  }
}
